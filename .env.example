# Server Configuration
PORT=8080
JWT_SECRET=your-secure-jwt-secret-key

# Database Configuration
DATABASE_URL=postgres://postgres:root@localhost:5432/go_auth?sslmode=disable

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Strategy Configuration
BCRYPT_COST=12
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_MINUTES=10
FORGOT_PASSWORD_OTP_TTL_MINUTES=10
RESET_TEMP_TOKEN_TTL_MINUTES=15

# Default Seed Data
SEED_ADMIN_EMAIL=admin@goauth.com
SEED_ADMIN_PASSWORD=Admin@123

# SMTP Configuration
IS_LOCAL_DEV_WITHOUT_SMTP=flase
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@GoAuth.com